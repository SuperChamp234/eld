+
+    # Convert pico-sdk printf variant selection into picolibc version
+    # when using pico_printf_compiler.
+    #
+    # GNU ld (ld.bfd) with picolibc supports the --printf=<variant> driver flag,
+    # which internally maps to --defsym=vfprintf=__<variant>_vfprintf.
+    # lld does not recognise --printf=<variant>, but it does support --defsym, so
+    # for clang builds we emit the equivalent -Wl,--defsym directly.
+
+    if (PICO_CLIB STREQUAL "picolibc")
+        if (PICO_C_COMPILER_IS_CLANG)
+            if (RUNTIME_INCLUDE_PRINTF_MINIMAL)
+                target_link_options(pico_standard_link INTERFACE
+                  $<$<STREQUAL:$<TARGET_PROPERTY:PICO_TARGET_PRINTF_IMPL>,pico_printf_compiler>:-Wl,--defsym=vfprintf=__m_vfprintf>)
+            elseif (RUNTIME_INCLUDE_PRINTF_FLOAT)
+                # this is the default
+            elseif (RUNTIME_INCLUDE_PRINTF_LONG_LONG)
+                target_link_options(pico_standard_link INTERFACE
+                  $<$<STREQUAL:$<TARGET_PROPERTY:PICO_TARGET_PRINTF_IMPL>,pico_printf_compiler>:-Wl,--defsym=vfprintf=__l_vfprintf>)
+            else()
+                target_link_options(pico_standard_link INTERFACE
+                  $<$<STREQUAL:$<TARGET_PROPERTY:PICO_TARGET_PRINTF_IMPL>,pico_printf_compiler>:-Wl,--defsym=vfprintf=__i_vfprintf>)
+            endif()
+        else()
+            if (RUNTIME_INCLUDE_PRINTF_MINIMAL)
+                target_link_options(pico_standard_link INTERFACE
+                  $<$<STREQUAL:$<TARGET_PROPERTY:PICO_TARGET_PRINTF_IMPL>,pico_printf_compiler>:--printf=m>)
+            elseif (RUNTIME_INCLUDE_PRINTF_FLOAT)
+                # this is the default
+            elseif (RUNTIME_INCLUDE_PRINTF_LONG_LONG)
+                target_link_options(pico_standard_link INTERFACE
+                  $<$<STREQUAL:$<TARGET_PROPERTY:PICO_TARGET_PRINTF_IMPL>,pico_printf_compiler>:--printf=l>)
+            else()
+                target_link_options(pico_standard_link INTERFACE
+                  $<$<STREQUAL:$<TARGET_PROPERTY:PICO_TARGET_PRINTF_IMPL>,pico_printf_compiler>:--printf=i>)
+            endif()
+        endif()
+    endif()
+
 endif()
