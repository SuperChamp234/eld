+++ b/src/rp2_common/hardware_exception/exception_table_riscv.S
@@ -11,7 +11,12 @@
 .endm
 
 // must be in RAM due to branches from vector table
-.section .time_critical.hardware_exception
+// "ax": SHF_ALLOC + SHF_EXECINSTR — required for lld to treat this as a
+// loadable code section. Without explicit flags, Clang's RISC-V assembler
+// emits the section with no SHF_ALLOC, causing lld to use P=0 for all
+// PC-relative relocations (R_RISCV_JAL, R_RISCV_PCREL_*), producing
+// ~512 MB offsets. GNU as infers flags from context; lld does not.
+.section .time_critical.hardware_exception, "ax", %progbits
 
 .p2align 2
 .global __riscv_exception_table
